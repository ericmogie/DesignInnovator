<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eric Mogensen | Design Innovation Lead</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Inter:wght@300;400;500;600;700&family=Sora:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg-primary: #0a0e1a;
  --bg-secondary: #111827;
  --bg-card: rgba(255,255,255,0.04);
  --bg-card-hover: rgba(255,255,255,0.07);
  --border-card: rgba(255,255,255,0.08);
  --border-card-hover: rgba(255,255,255,0.18);
  --text-primary: #f0f2f5;
  --text-secondary: #9ca3b4;
  --text-muted: #6b7280;
  --accent-blue: #7cacf8;
  --accent-orange: #f6a856;
  --accent-coral: #f87171;
  --accent-teal: #5eead4;
  --accent-purple: #c4b5fd;
  --accent-lime: #a3e635;
  --font-display: 'Inter', -apple-system, sans-serif;
  --font-body: 'Inter', -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
  --max-width: 1200px;
  --section-gap: 160px;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font-body);
  background: var(--bg-primary);
  color: var(--text-primary);
  line-height: 1.6;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { color: var(--accent-blue); text-decoration: none; transition: color 0.2s; }
a:hover { color: #a8cbff; }

/* ============ NAV ============ */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(10,14,26,0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border-card);
}
.nav-inner {
  max-width: var(--max-width); margin: 0 auto; padding: 0 32px;
  height: 64px; display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
  display: flex; align-items: center; height: 100%;
}
.nav-logo svg { height: 34px; width: auto; }
.nav-logo-text { display: none; }
.nav-links { display: flex; gap: 32px; align-items: center; }
.nav-links a { font-size: 14px; font-weight: 500; color: var(--text-secondary); transition: color 0.2s; }
.nav-links a:hover { color: var(--text-primary); }
.nav-cta {
  background: rgba(255,255,255,0.1) !important; color: var(--text-primary) !important;
  padding: 8px 20px; border-radius: 20px; font-size: 14px !important;
  border: 1px solid var(--border-card); transition: all 0.2s !important;
}
.nav-cta:hover { background: rgba(255,255,255,0.15) !important; border-color: var(--border-card-hover) !important; }

/* ============ HERO ============ */
.hero {
  position: relative; padding: 180px 32px 140px;
  text-align: center; overflow: hidden;
}

/* Animated mesh gradient background */
.hero-bg {
  position: absolute; inset: -100px; z-index: 0; pointer-events: none;
  overflow: hidden;
}
.hero-bg .orb {
  position: absolute; border-radius: 50%; filter: blur(100px); opacity: 0.5;
  animation: orbFloat 12s ease-in-out infinite;
}
.hero-bg .orb-1 {
  width: 600px; height: 600px; top: -150px; left: 10%;
  background: radial-gradient(circle, rgba(124,172,248,0.35) 0%, transparent 70%);
  animation-duration: 14s;
}
.hero-bg .orb-2 {
  width: 500px; height: 500px; top: -80px; right: 5%;
  background: radial-gradient(circle, rgba(246,168,86,0.3) 0%, transparent 70%);
  animation-duration: 10s; animation-delay: -3s;
}
.hero-bg .orb-3 {
  width: 450px; height: 450px; bottom: -100px; left: 30%;
  background: radial-gradient(circle, rgba(248,113,113,0.25) 0%, transparent 70%);
  animation-duration: 16s; animation-delay: -7s;
}
.hero-bg .orb-4 {
  width: 350px; height: 350px; top: 50%; left: 55%;
  background: radial-gradient(circle, rgba(196,181,253,0.2) 0%, transparent 70%);
  animation-duration: 11s; animation-delay: -5s;
}
.hero-bg .orb-5 {
  width: 300px; height: 300px; top: 20%; right: 25%;
  background: radial-gradient(circle, rgba(94,234,212,0.2) 0%, transparent 70%);
  animation-duration: 13s; animation-delay: -2s;
}
/* Grain overlay */
.hero-bg::after {
  content: ''; position: absolute; inset: 0;
  background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  opacity: 0.6;
}

@keyframes orbFloat {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(30px, -20px) scale(1.05); }
  50% { transform: translate(-20px, 15px) scale(0.95); }
  75% { transform: translate(15px, 25px) scale(1.02); }
}

.hero > *:not(.hero-bg) { position: relative; z-index: 1; }

.hero-label {
  font-family: var(--font-mono); font-size: 14px; color: var(--accent-teal);
  letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 24px;
  opacity: 0; animation: fadeUp 0.6s 0.2s forwards;
}
.hero h1 {
  font-family: var(--font-display); font-size: clamp(48px, 7vw, 82px);
  font-weight: 700; line-height: 1.05; letter-spacing: -0.03em; margin-bottom: 28px;
  opacity: 0; animation: fadeUp 0.6s 0.4s forwards;
}
.hero h1 .gradient-text {
  background: linear-gradient(135deg, #7cacf8 0%, #5eead4 30%, #f6a856 60%, #f87171 100%);
  background-size: 200% 200%;
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  animation: gradientShift 8s ease-in-out infinite;
}
@keyframes gradientShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}
.hero-sub {
  font-size: 18px; color: var(--text-secondary); max-width: 620px;
  margin: 0 auto 44px; line-height: 1.75;
  opacity: 0; animation: fadeUp 0.6s 0.6s forwards;
}
.hero-cta {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 14px 32px; background: var(--accent-blue); color: #0a0e1a;
  font-weight: 600; font-size: 15px; border-radius: 24px; transition: all 0.3s;
  opacity: 0; animation: fadeUp 0.6s 0.8s forwards;
}
.hero-cta:hover {
  background: #a8cbff; color: #0a0e1a; transform: translateY(-1px);
  box-shadow: 0 8px 30px rgba(124,172,248,0.3);
}
.hero-cta svg { width: 16px; height: 16px; }

/* ============ SECTIONS ============ */
.section { max-width: var(--max-width); margin: 0 auto; padding: 0 32px; }
.section-gap { margin-top: var(--section-gap); }
.section-label {
  font-family: var(--font-mono); font-size: 13px; color: var(--accent-orange);
  letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px;
}
.section-heading {
  font-family: var(--font-display); font-size: clamp(32px, 4vw, 48px);
  font-weight: 700; letter-spacing: -0.02em; line-height: 1.15; margin-bottom: 20px;
}
.section-body {
  font-size: 17px; color: var(--text-secondary); max-width: 640px; line-height: 1.7;
}

/* ============ CASE STUDY CARDS ============ */
.cases-grid {
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 64px;
}

.case-card {
  position: relative; border: 1px solid var(--border-card); border-radius: 20px;
  padding: 40px; transition: all 0.4s; overflow: hidden; cursor: pointer;
  background: var(--bg-card);
}
/* Inner gradient glow per card */
.case-card::before {
  content: ''; position: absolute; top: -60%; right: -30%;
  width: 300px; height: 300px; border-radius: 50%;
  background: var(--card-glow, rgba(124,172,248,0.06));
  filter: blur(60px); transition: opacity 0.4s; opacity: 0.5;
  pointer-events: none;
}
.case-card:hover::before { opacity: 1; }
/* Top accent bar */
.case-card::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--card-accent, var(--accent-blue));
  opacity: 0; transition: opacity 0.35s;
}
.case-card:hover::after { opacity: 1; }
.case-card:hover {
  border-color: var(--border-card-hover); transform: translateY(-3px);
  box-shadow: 0 20px 60px rgba(0,0,0,0.3);
}

/* Decorative geometric shapes inside cards */
.case-deco {
  position: absolute; pointer-events: none; opacity: 0.08; transition: opacity 0.4s;
}
.case-card:hover .case-deco { opacity: 0.15; }

.case-number {
  font-family: var(--font-mono); font-size: 12px; color: var(--text-muted);
  margin-bottom: 16px; position: relative; z-index: 1;
}
.case-title {
  font-family: var(--font-display); font-size: 22px; font-weight: 600;
  letter-spacing: -0.01em; margin-bottom: 12px; color: var(--text-primary);
  position: relative; z-index: 1;
}
.case-problem {
  font-size: 15px; color: var(--text-secondary); line-height: 1.65;
  margin-bottom: 20px; position: relative; z-index: 1;
}
.case-tags { display: flex; flex-wrap: wrap; gap: 8px; position: relative; z-index: 1; }
.case-tag {
  font-family: var(--font-mono); font-size: 11px; padding: 4px 12px;
  border-radius: 100px; transition: all 0.3s;
}

/* Card-specific color themes */
.card-orange { --card-accent: #f6a856; --card-glow: rgba(246,168,86,0.1); }
.card-orange .case-tag { color: #f6a856; background: rgba(246,168,86,0.1); border: 1px solid rgba(246,168,86,0.2); }

.card-teal { --card-accent: #5eead4; --card-glow: rgba(94,234,212,0.1); }
.card-teal .case-tag { color: #5eead4; background: rgba(94,234,212,0.1); border: 1px solid rgba(94,234,212,0.2); }

.card-purple { --card-accent: #c4b5fd; --card-glow: rgba(196,181,253,0.1); }
.card-purple .case-tag { color: #c4b5fd; background: rgba(196,181,253,0.1); border: 1px solid rgba(196,181,253,0.2); }

.card-coral { --card-accent: #f87171; --card-glow: rgba(248,113,113,0.1); }
.card-coral .case-tag { color: #f87171; background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.2); }

.card-blue { --card-accent: #7cacf8; --card-glow: rgba(124,172,248,0.1); }
.card-blue .case-tag { color: #7cacf8; background: rgba(124,172,248,0.1); border: 1px solid rgba(124,172,248,0.2); }

.card-lime { --card-accent: #a3e635; --card-glow: rgba(163,230,53,0.08); }
.card-lime .case-tag { color: #a3e635; background: rgba(163,230,53,0.08); border: 1px solid rgba(163,230,53,0.18); }

/* Featured card */
.case-card.featured {
  grid-column: 1 / -1; display: grid; grid-template-columns: 1fr 1fr;
  gap: 48px; align-items: center;
}
.case-visual {
  background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
  border-radius: 14px; aspect-ratio: 16/10; display: flex;
  align-items: center; justify-content: center;
  border: 1px solid rgba(255,255,255,0.06); overflow: hidden; position: relative;
}
/* Animated scan line in visual placeholder */
.case-visual::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--card-accent, var(--accent-orange)), transparent);
  animation: scanLine 4s ease-in-out infinite;
}
@keyframes scanLine {
  0%, 100% { top: 0; opacity: 0; }
  10% { opacity: 0.6; }
  90% { opacity: 0.6; }
  100% { top: 100%; opacity: 0; }
}
.case-visual-placeholder {
  font-family: var(--font-mono); font-size: 13px; color: var(--text-muted);
  text-align: center; padding: 20px; line-height: 1.6;
}
.case-visual-placeholder em {
  display: block; margin-top: 8px; font-size: 11px;
  color: var(--accent-orange); font-style: normal;
}

/* ============ CAPABILITIES ============ */
.cap-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px;
}
.cap-card {
  background: var(--bg-card); border: 1px solid var(--border-card);
  border-radius: 16px; padding: 32px; transition: all 0.35s;
  position: relative; overflow: hidden;
}
.cap-card::before {
  content: ''; position: absolute; bottom: -40px; right: -40px;
  width: 120px; height: 120px; border-radius: 50%;
  background: var(--cap-glow, rgba(124,172,248,0.06));
  filter: blur(40px); transition: opacity 0.4s; opacity: 0.4;
}
.cap-card:hover {
  background: var(--bg-card-hover); border-color: var(--border-card-hover);
  transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0,0,0,0.2);
}
.cap-card:hover::before { opacity: 0.8; }
.cap-icon {
  width: 44px; height: 44px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 20px; font-size: 20px;
}
.cap-title { font-family: var(--font-display); font-size: 16px; font-weight: 600; margin-bottom: 10px; }
.cap-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.65; }

/* ============ ABOUT ============ */
.about-section {
  max-width: var(--max-width); margin: var(--section-gap) auto 0; padding: 0 32px;
}
.about-card {
  background: var(--bg-card); border: 1px solid var(--border-card);
  border-radius: 24px; padding: 80px; position: relative; overflow: hidden;
}
.about-card::before {
  content: ''; position: absolute; top: -100px; right: -100px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(246,168,86,0.08) 0%, rgba(94,234,212,0.04) 50%, transparent 70%);
  pointer-events: none; animation: orbFloat 20s ease-in-out infinite;
}
.about-columns { display: grid; grid-template-columns: 1fr 1.5fr; gap: 64px; align-items: start; }
.about-meta { position: sticky; top: 100px; }
.about-meta h2 {
  font-family: var(--font-display); font-size: 36px; font-weight: 700;
  letter-spacing: -0.02em; margin-bottom: 8px;
}
.about-meta .role { font-family: var(--font-mono); font-size: 14px; color: var(--accent-teal); margin-bottom: 24px; }
.about-stats { display: flex; flex-direction: column; gap: 16px; margin-top: 32px; }
.about-stat { display: flex; gap: 12px; align-items: baseline; }
.about-stat .num {
  font-family: var(--font-display); font-size: 28px; font-weight: 700;
  color: var(--text-primary); min-width: 60px;
}
.about-stat .num.blue { color: var(--accent-blue); }
.about-stat .num.orange { color: var(--accent-orange); }
.about-stat .num.teal { color: var(--accent-teal); }
.about-stat .label { font-size: 14px; color: var(--text-secondary); }
.about-prose p { font-size: 16px; color: var(--text-secondary); line-height: 1.8; margin-bottom: 20px; }
.about-prose p:last-child { margin-bottom: 0; }

/* ============ EXPERIENCE ============ */
.exp-timeline { margin-top: 48px; position: relative; }
.exp-timeline::before {
  content: ''; position: absolute; left: 120px; top: 0; bottom: 0; width: 1px;
  background: linear-gradient(to bottom, var(--accent-blue), var(--accent-teal), var(--accent-orange), var(--accent-coral));
  opacity: 0.3;
}
.exp-item {
  display: grid; grid-template-columns: 120px 1fr; gap: 48px;
  padding: 32px 0; position: relative;
}
.exp-item + .exp-item { border-top: 1px solid rgba(255,255,255,0.04); }
.exp-year {
  font-family: var(--font-mono); font-size: 13px; color: var(--text-muted);
  text-align: right; padding-top: 4px;
}
.exp-dot {
  position: absolute; left: 116px; top: 36px; width: 9px; height: 9px;
  border-radius: 50%; border: 2px solid var(--bg-primary);
}
.exp-dot.d1 { background: var(--accent-blue); }
.exp-dot.d2 { background: var(--accent-teal); }
.exp-dot.d3 { background: var(--accent-purple); }
.exp-dot.d4 { background: var(--accent-orange); }
.exp-dot.d5 { background: var(--accent-coral); }
.exp-dot.d6 { background: var(--accent-lime); }
.exp-dot.d7 { background: var(--accent-blue); }
.exp-content h3 { font-family: var(--font-display); font-size: 18px; font-weight: 600; margin-bottom: 4px; }
.exp-company { font-size: 14px; color: var(--accent-blue); margin-bottom: 10px; }
.exp-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.7; max-width: 560px; }

/* ============ CTA SECTION ============ */
.cta-section {
  margin-top: var(--section-gap); text-align: center;
  padding: 100px 32px 120px; position: relative; overflow: hidden;
}
.cta-section::before {
  content: ''; position: absolute; bottom: -50px; left: 50%; transform: translateX(-50%);
  width: 900px; height: 500px;
  background: radial-gradient(ellipse, rgba(94,234,212,0.08) 0%, rgba(124,172,248,0.05) 30%, rgba(248,113,113,0.04) 60%, transparent 80%);
  pointer-events: none; animation: orbFloat 18s ease-in-out infinite;
}
.cta-heading {
  font-family: var(--font-display); font-size: clamp(28px, 4vw, 42px);
  font-weight: 700; letter-spacing: -0.02em; margin-bottom: 16px;
}
.cta-body {
  font-size: 17px; color: var(--text-secondary); max-width: 520px;
  margin: 0 auto 36px; line-height: 1.7;
}
.cta-links { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }
.cta-links a {
  padding: 12px 28px; border-radius: 24px; font-size: 15px; font-weight: 500; transition: all 0.3s;
}
.cta-links .primary { background: var(--accent-blue); color: #0a0e1a; }
.cta-links .primary:hover { background: #a8cbff; box-shadow: 0 8px 30px rgba(124,172,248,0.3); }
.cta-links .secondary {
  background: rgba(255,255,255,0.08); color: var(--text-primary); border: 1px solid var(--border-card);
}
.cta-links .secondary:hover { background: rgba(255,255,255,0.12); border-color: var(--border-card-hover); }

/* ============ FOOTER ============ */
footer { border-top: 1px solid var(--border-card); padding: 60px 32px 48px; }
.footer-inner {
  max-width: var(--max-width); margin: 0 auto;
}
.footer-top {
  display: flex; justify-content: space-between; align-items: flex-start;
  margin-bottom: 48px; gap: 40px;
}
.footer-brand svg { height: 48px; width: auto; margin-bottom: 20px; display: block; }
.footer-tagline {
  font-size: 14px; color: var(--text-muted); line-height: 1.6; max-width: 320px;
}
.footer-nav { display: flex; gap: 48px; }
.footer-nav-col h4 {
  font-family: var(--font-mono); font-size: 11px; color: var(--text-muted);
  letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 16px;
}
.footer-nav-col a {
  display: block; font-size: 14px; color: var(--text-secondary);
  margin-bottom: 10px; transition: color 0.2s;
}
.footer-nav-col a:hover { color: var(--text-primary); }
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.05); padding-top: 24px;
  display: flex; justify-content: space-between; align-items: center;
}
.footer-copy { font-size: 12px; color: var(--text-muted); }
.footer-bottom-links { display: flex; gap: 20px; }
.footer-bottom-links a { font-size: 12px; color: var(--text-muted); transition: color 0.2s; }
.footer-bottom-links a:hover { color: var(--text-secondary); }

/* ============ ANIMATIONS ============ */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
.reveal {
  opacity: 0; transform: translateY(30px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* Stagger children */
.cases-grid .reveal:nth-child(2) { transition-delay: 0.1s; }
.cases-grid .reveal:nth-child(3) { transition-delay: 0.2s; }
.cases-grid .reveal:nth-child(4) { transition-delay: 0.3s; }
.cases-grid .reveal:nth-child(5) { transition-delay: 0.35s; }
.cases-grid .reveal:nth-child(6) { transition-delay: 0.4s; }

.cap-grid .reveal:nth-child(2) { transition-delay: 0.08s; }
.cap-grid .reveal:nth-child(3) { transition-delay: 0.16s; }
.cap-grid .reveal:nth-child(4) { transition-delay: 0.24s; }
.cap-grid .reveal:nth-child(5) { transition-delay: 0.32s; }
.cap-grid .reveal:nth-child(6) { transition-delay: 0.4s; }

/* ============ RESPONSIVE ============ */
@media (max-width: 900px) {
  .cases-grid { grid-template-columns: 1fr; }
  .case-card.featured { grid-template-columns: 1fr; }
  .cap-grid { grid-template-columns: 1fr; }
  .about-columns { grid-template-columns: 1fr; }
  .about-card { padding: 40px; }
  .exp-timeline::before { display: none; }
  .exp-item { grid-template-columns: 1fr; gap: 4px; }
  .exp-year { text-align: left; }
  .exp-dot { display: none; }
  .nav-links { gap: 20px; }
  :root { --section-gap: 100px; }
  .footer-top { flex-direction: column; }
  .footer-nav { gap: 32px; }
  .footer-bottom { flex-direction: column; gap: 12px; align-items: flex-start; }
}
@media (max-width: 600px) {
  .hero { padding: 140px 20px 80px; }
  .section { padding: 0 20px; }
  .nav-inner { padding: 0 20px; }
  .nav-links a:not(.nav-cta) { display: none; }
}
